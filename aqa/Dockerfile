# Используем легковесный образ с Java
FROM eclipse-temurin:17-jdk

# Устанавливаем рабочую директорию внутри контейнера
WORKDIR /app

# Эта команда берет JAR-файл из папки aqa (потому что мы указали context: ./aqa в docker-compose) и копирует его в контейнер под новым,
# универсальным именем service.jar. Теперь, даже если пересобрать проект и версия изменится (например, на internal-0.0.2-SNAPSHOT.jar),
# то нужно будет поменять имя только в Dockerfile, а не в команде запуска
# Копируем скомпилированный JAR-файл сервиса в контейнер
COPY internal-0.0.1-SNAPSHOT.jar service.jar

# Запускаем сервис
CMD ["java", "-jar", "/app/service.jar"]